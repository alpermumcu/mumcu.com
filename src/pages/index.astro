---
import Layout from '../layouts/Layout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getCollection } from 'astro:content';
import doctorPhoto from '../images/uploads/2020/08/alper-mumcu-photo.jpg';
import { getHeroImage } from '../data/category-defaults';
import PregnancyCalculator from '../components/PregnancyCalculator.astro';

// Category Images
import imgGebelik from '../images/categories/gebelik.png';
import imgJinekoloji from '../images/categories/jinekoloji.png';
import imgTupBebek from '../images/categories/tup-bebek.png';
import imgCerrahi from '../images/categories/cerrahi.png';
import imgEstetik from '../images/categories/estetik.png';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const faqItems = [
	{ 
		question: "İlk randevu için ne getirmeliyim?", 
		answer: "Varsa eski tahlil sonuçlarınız ve kullandığınız ilaçların listesinin yanınızda bulunması, sürecin hızlanması ve daha sağlıklı değerlendirilmesi için yararlı olacaktır." 
	},
	{ 
		question: "Randevu saati nasıl belirlenir?", 
		answer: "Online randevu formunu doldurduğunuzda veya WhatsApp hattımızdan ulaştığınızda, asistanımız size en uygun gün ve saat seçeneklerini sunarak randevunuzu kesinleştirecektir." 
	},
	{ 
		question: "Muayenehane nerede bulunuyor?", 
		answer: "Kliniğimiz Şişli Nişantaşı'nda, Lotus Nişantaşı kompleksinde (Halaskargazi Cd. No:38-66) Kat: 5, Daire: 93 adresinde yer almaktadır. Metro ile kolayca ulaşılabilir." 
	},
	{ 
		question: "Hangi hastaneler ile çalışıyorsunuz?", 
		answer: "Ameliyat ve doğumlarımızı hastanın tercihi ve tıbbi gerekliliklere göre Amerikan Hastanesi, Acıbadem Grubu ve Nişantaşı Hastanesi gibi tam teşekküllü merkezlerde gerçekleştirmekteyiz." 
	}
];
---

<Layout title="Dr. Alper Mumcu | Kadın Hastalıkları ve Doğum Uzmanı">
	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="container hero-content">
				<div class="hero-text">
					<div class="trust-badges">
						<span class="trust-badge">✨ 25+ Yıl Deneyim</span>
						<span class="trust-badge">📍 Lotus Nişantaşı</span>
						<span class="trust-badge">🧪 Bilimsel Yaklaşım</span>
					</div>
					<h1>Deneyim ve Bilim Işığında <br/><span class="text-gradient">Kadın Sağlığı, Hamilelik & İnfertilite</span></h1>
					<p>Kadın sağlığı, hamilelik ve infertilite hakkında güncel ve güvenilir bilgiler.</p>
					<div class="hero-actions">
						<a href="/online-randevu" class="btn btn-primary">Randevu Talebi</a>
						<a href="/iletisim" class="btn btn-outline">Yol Tarifi Al</a>
					</div>
				</div>
				<div class="hero-decoration">
					<div class="blob"></div>
					<div class="hero-stats">
						<div class="stat-item">
							<strong>600+</strong>
							<span>Tıbbi Makale</span>
						</div>
						<div class="stat-item">
							<strong>10k+</strong>
							<span>Bebek Takibi</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Services / Category Grid -->
		<section class="services" id="hizmetler">
			<div class="container">
				<div class="section-header">
					<h2 class="font-outfit">Uzmanlık Alanları</h2>
					<p>Her yaştan kadın için bilimsel temelli, güvenilir ve güncel sağlık hizmetleri.</p>
				</div>
				<div class="category-grid">
					<CategoryCard 
						href="/category/gebelik-dogum/" 
						title="Gebelik & Doğum" 
						description="Hafta hafta gebelik takibi ve modern doğum yöntemleri."
						image={imgGebelik.src}
						count={303}
					/>
					<CategoryCard 
						href="/category/jinekoloji/" 
						title="Jinekoloji" 
						description="Rutin kontroller, HPV takibi ve kadın sağlığı çözümleri."
						image={imgJinekoloji.src}
						count={235}
					/>
					<CategoryCard 
						href="/category/tup-bebek-infertilite/" 
						title="Tüp Bebek & İnfertilite" 
						description="Üreme sağlığı ve modern tüp bebek teknolojileri."
						image={imgTupBebek.src}
						count={51}
					/>
					<CategoryCard 
						href="/category/cerrahi-islemler/" 
						title="Cerrahi İşlemler" 
						description="Laparoskopik ve minimal invaziv cerrahi teknikler."
						image={imgCerrahi.src}
						count={5}
					/>
					<CategoryCard 
						href="/category/estetik-jinekoloji/" 
						title="Estetik Jinekoloji" 
						description="Lazer uygulamaları ve genital estetik çözümleri."
						image={imgEstetik.src}
						count={3}
					/>
				</div>
			</div>
		</section>

		<!-- Doctor Profile Section -->
		<section class="doctor-profile">
			<div class="container">
				<div class="profile-card glass">
					<div class="profile-content">
						<h2 class="font-outfit">Dr. Alper Mumcu</h2>
						<p class="subtitle">Kadın Hastalıkları ve Doğum Uzmanı</p>
						<p class="bio">
							1998 yılından bu yana kadın sağlığı, riskli gebelik takibi ve tüp bebek alanlarında binlerce hastaya hizmet vermiş olan Dr. Alper Mumcu, Lotus Nişantaşı'ndaki kliniğinde modern tıbbın tüm imkanlarını hastalarıyla buluşturmaktadır.
						</p>
						<div class="affiliations">
							<strong>Üyelikler & Bağlantılar:</strong>
							<div class="affiliation-logos">
								<span>TJOD</span>
								<span>TSRM</span>
								<span>ESHRE</span>
								<span>ASRM</span>
							</div>
						</div>
						<a href="/dr-alper-mumcu" class="btn btn-outline">Hakkımda Daha Fazla Bilgi</a>
					</div>
					<div class="profile-image-container">
						<div class="image-accent"></div>
						<div class="profile-image">
							<img src={doctorPhoto.src} alt="Dr. Alper Mumcu" class="doctor-img" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ Section -->
		<section class="faq-section">
			<div class="container">
				<div class="section-header">
					<h2 class="font-outfit">Sıkça Sorulan Sorular</h2>
					<p>Muayene süreci ve merak ettiğiniz genel konular.</p>
				</div>
				<FAQAccordion items={faqItems} />
			</div>
		</section>

		<!-- Latest Blog Posts -->
		<section class="blog-preview">
			<div class="container glass blog-container">
				<div class="section-header">
					<h2 class="font-outfit">Bilgi Kütüphanesi</h2>
					<p>Kadın sağlığı ve hamilelik üzerine en güncel paylaşımlar.</p>
				</div>
				<div class="grid">
					{posts.map((post) => (
						<article class="post-card">
							<div class="post-image">
								<img src={getHeroImage(post.slug, (post.data.category || [])[0], post.data.heroImage)} alt={post.data.title} loading="lazy" />
							</div>
							<div class="post-content">
								<div class="post-meta">
									<span class="post-date">{post.data.pubDate.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric'})}</span>
									<span class="post-cat">{(post.data.category || [])[0]}</span>
								</div>
								<h3>{post.data.title}</h3>
								<a href={`/blog/${post.slug}/`} class="more-link">Devamını Oku &rarr;</a>
							</div>
						</article>
					))}
				</div>
				<div class="view-all">
					<a href="/blog/" class="btn btn-primary">Tüm Kütüphaneyi Keşfet</a>
				</div>
			</div>
		</section>

		<PregnancyCalculator />
	</main>
</Layout>

<style>
	/* Hero Section */
	.hero {
		min-height: 85vh;
		display: flex;
		align-items: center;
		padding-top: 6rem;
		background: radial-gradient(circle at 10% 20%, hsl(var(--secondary) / 0.5), transparent 50%);
		position: relative;
		overflow: hidden;
	}
	.hero-content {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 4rem;
		align-items: center;
		position: relative;
		z-index: 2;
	}
	.hero-text h1 {
		font-size: 4rem;
		line-height: 1.1;
		margin: 1.5rem 0;
		color: hsl(var(--text-main));
		font-weight: 800;
	}
	.hero-text p {
		font-size: 1.25rem;
		color: hsl(var(--text-muted));
		margin-bottom: 2.5rem;
		max-width: 550px;
		line-height: 1.6;
	}
	.trust-badges {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.trust-badge {
		background: white;
		color: hsl(var(--text-main));
		padding: 0.5rem 1rem;
		border-radius: 99px;
		font-size: 0.85rem;
		font-weight: 700;
		border: 1px solid var(--glass-border);
		box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
	}

	/* Stats Overlay */
	.hero-decoration {
		position: relative;
		height: 400px;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.hero-stats {
		position: relative;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		z-index: 5;
	}
	.stat-item {
		background: white;
		padding: 2rem;
		border-radius: 24px;
		text-align: center;
		border: 1px solid var(--glass-border);
		box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.05);
	}
	.stat-item strong {
		display: block;
		font-size: 2.5rem;
		color: hsl(var(--primary));
		font-family: 'Outfit', sans-serif;
		line-height: 1;
		margin-bottom: 0.5rem;
	}
	.stat-item span {
		font-size: 0.9rem;
		font-weight: 700;
		color: hsl(var(--text-muted));
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.blob {
		position: absolute;
		width: 450px;
		height: 450px;
		background: var(--accent-gradient);
		filter: blur(100px);
		border-radius: 50%;
		opacity: 0.15;
		animation: drift 15s infinite alternate ease-in-out;
	}

	/* Grid Layouts */
	.category-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
		gap: 2rem;
	}

	/* Section Headers */
	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}
	.section-header h2 {
		font-size: 3rem;
		margin-bottom: 1rem;
		color: hsl(var(--text-main));
		font-weight: 800;
	}
	.section-header p {
		color: hsl(var(--text-muted));
		font-size: 1.2rem;
		max-width: 600px;
		margin: 0 auto;
	}

	/* Doctor Profile */
	.doctor-profile {
		padding: 100px 0;
		background: hsl(var(--accent) / 0.02);
	}
	.profile-card {
		display: grid;
		grid-template-columns: 1fr 350px;
		gap: 3rem;
		padding: 4rem;
		border-radius: 40px;
		align-items: center;
	}
	.profile-content h2 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}
	.subtitle {
		color: hsl(var(--accent));
		font-weight: 700;
		font-size: 1.1rem;
		margin-bottom: 1.5rem;
	}
	.bio {
		font-size: 1.15rem;
		line-height: 1.7;
		margin-bottom: 2rem;
		color: hsl(var(--text-muted));
	}
	.affiliations {
		margin-bottom: 2.5rem;
	}
	.affiliation-logos {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}
	.affiliation-logos span {
		background: white;
		padding: 0.4rem 0.8rem;
		border-radius: 8px;
		font-size: 0.8rem;
		font-weight: 800;
		border: 1px solid var(--glass-border);
		color: hsl(var(--text-muted));
	}
	.profile-image-container {
		position: relative;
		height: 450px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.image-accent {
		position: absolute;
		width: 110%;
		height: 110%;
		background: linear-gradient(135deg, hsl(var(--accent) / 0.1), transparent);
		border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
		animation: morph 8s ease-in-out infinite;
		z-index: 1;
	}
	.profile-image {
		position: relative;
		z-index: 2;
		width: 350px;
		height: 450px;
		overflow: hidden;
		border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
		box-shadow: var(--shadow-xl);
		border: 4px solid white;
		background: white;
	}
	.doctor-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top;
		transition: transform 0.5s ease;
	}
	.profile-image:hover .doctor-img {
		transform: scale(1.05);
	}

	@keyframes morph {
		0% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
		50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
		100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
	}

	/* FAQ Section */
	.faq-section {
		padding: 100px 0;
	}

	/* Blog Preview */
	.post-card {
		background: white;
		border-radius: 20px;
		transition: all 0.3s ease;
		border: 1px solid var(--glass-border);
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}
	.post-image {
		height: 180px;
		width: 100%;
		overflow: hidden;
		background: hsl(var(--secondary) / 0.3);
	}
	.post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}
	.post-card:hover .post-image img {
		transform: scale(1.1);
	}
	.post-content {
		padding: 2rem;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}
	.post-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
	}
	.post-meta {
		display: flex;
		justify-content: space-between;
		margin-bottom: 1rem;
		font-size: 0.8rem;
		font-weight: 700;
	}
	.post-date { color: hsl(var(--text-muted)); }
	.post-cat { color: hsl(var(--accent)); text-transform: uppercase; }
	
	.post-card h3 {
		font-size: 1.3rem;
		margin-bottom: 1.5rem;
		line-height: 1.4;
		color: hsl(var(--text-main));
	}

	.more-link {
		margin-top: auto;
		display: inline-flex;
		align-items: center;
		color: hsl(var(--accent));
		text-decoration: none;
		font-weight: 800;
		font-size: 0.95rem;
		gap: 0.5rem;
		transition: all 0.3s ease;
		position: relative;
		width: fit-content;
	}

	.more-link::after {
		content: '';
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 0;
		height: 2px;
		background: hsl(var(--accent));
		transition: width 0.3s ease;
	}

	.more-link:hover {
		gap: 0.75rem;
		color: hsl(var(--accent) / 0.8);
	}

	.more-link:hover::after {
		width: 100%;
	}

	.btn {
		padding: 1rem 2rem;
		border-radius: 14px;
		font-weight: 700;
		text-decoration: none;
		display: inline-block;
		transition: all 0.3s ease;
	}
	.btn-primary {
		background: var(--accent-gradient);
		color: white;
	}
	.btn-outline {
		border: 1px solid var(--glass-border);
		color: hsl(var(--text-main));
	}
	.btn:hover {
		transform: translateY(-2px);
		filter: brightness(1.1);
	}

	@media (max-width: 1024px) {
		.hero-content { grid-template-columns: 1fr; text-align: center; }
		.hero-text h1 { font-size: 3rem; }
		.hero-actions, .trust-badges { justify-content: center; }
		.hero-decoration { display: none; }
		.profile-card { grid-template-columns: 1fr; padding: 2rem; }
		.profile-image-placeholder { display: none; }
	}
</style>
