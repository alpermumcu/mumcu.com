---
import Layout from '../layouts/Layout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getCollection } from 'astro:content';
import doctorPhoto from '../images/uploads/2020/08/alper-mumcu-photo.jpg';
import doctorClinicPhoto from '../images/hero/dr-alper-clinical-hero.png';
import { getHeroImage } from '../data/category-defaults';
import PregnancyCalculator from '../components/PregnancyCalculator.astro';

// Category Images
import imgGebelik from '../images/categories/gebelik.png';
import imgJinekoloji from '../images/categories/jinekoloji.png';
import imgTupBebek from '../images/categories/tup-bebek.png';
import imgCerrahi from '../images/categories/cerrahi.png';
import imgEstetik from '../images/categories/estetik.png';

// Clinic Gallery
import clinicEntrance from '../images/clinic/lotus-entrance.jpg';
import clinicCorridor from '../images/clinic/lotus-corridor.jpg';
import clinicConsultation from '../images/clinic/lotus-consultation.jpg';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const faqItems = [
	{ 
		question: "İlk randevu için ne getirmeliyim?", 
		answer: "Varsa eski tahlil sonuçlarınız ve kullandığınız ilaçların listesinin yanınızda bulunması, sürecin hızlanması ve daha sağlıklı değerlendirilmesi için yararlı olacaktır." 
	},
	{ 
		question: "Randevu saati nasıl belirlenir?", 
		answer: "Online randevu formunu doldurduğunuzda veya WhatsApp hattımızdan ulaştığınızda, asistanımız size en uygun gün ve saat seçeneklerini sunarak randevunuzu kesinleştirecektir." 
	},
	{ 
		question: "Muayenehane nerede bulunuyor?", 
		answer: "Kliniğimiz Şişli Nişantaşı'nda, Lotus Nişantaşı kompleksinde (Halaskargazi Cd. No:38-66) Kat: 5, Daire: 93 adresinde yer almaktadır. Metro ile kolayca ulaşılabilir." 
	},
	{ 
		answer: "Ameliyat ve doğumlarımızı hastanın tercihi ve tıbbi gerekliliklere göre Acıbadem Grubu ve Nişantaşı Hastanesi gibi tam teşekküllü merkezlerde gerçekleştirmekteyiz." 
	}
];
---

<Layout title="Dr. Alper Mumcu | Kadın Hastalıkları ve Doğum Uzmanı">
	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="hero-bg-orb hero-bg-orb--1" aria-hidden="true"></div>
			<div class="hero-bg-orb hero-bg-orb--2" aria-hidden="true"></div>
			<div class="container hero-content">
				<div class="hero-text">
					<div class="trust-badges">
						<span class="trust-badge"><span class="badge-dot green"></span> Kıdemli Uzmanlık</span>
						<span class="trust-badge"><span class="badge-dot pink"></span> Nişantaşı Lotus</span>
						<span class="trust-badge"><span class="badge-dot blue"></span> Akademik Profil</span>
					</div>
					<h1 class="font-outfit">Deneyim ve Bilim Işığında <br/><span class="text-gradient">Kadın Sağlığı, Hamilelik & İnfertilite</span></h1>
					<p class="hero-intro">Kadın sağlığı, riskli gebelik takibi ve üreme sağlığı alanlarında uzun yıllara dayanan uzmanlık ve akademik derinlikle yanınızdayız.</p>

					<div class="hero-actions">
						<a href="/online-randevu" class="btn btn-primary">Randevu Talebi</a>
						<a href="/iletisim" class="btn btn-outline">İletişim & Konum</a>
					</div>
				</div>

				<div class="hero-visual">
					<div class="image-stack">
						<div class="main-image-frame">
							<img src={doctorClinicPhoto.src} alt="Dr. Alper Mumcu Klinik Ortamında" class="hero-img-main" />
							<div class="image-overlay-gradient"></div>
						</div>
						
						<!-- Floating Labels (Ethical & Final) -->
						<div class="floating-box stat-experience">
							<div class="stat-icon">🏥</div>
							<div class="stat-info">
								<strong>Kıdemli</strong>
								<span>Uzman Doktor</span>
							</div>
						</div>
						
						<div class="floating-box stat-babies">
							<div class="stat-icon">🤰</div>
							<div class="stat-info">
								<strong>Riskli Gebelik</strong>
								<span>Uzman Takip</span>
							</div>
						</div>

						<div class="floating-box stat-articles">
							<div class="stat-icon">🎓</div>
							<div class="stat-info">
								<strong>Akademik</strong>
								<span>Derinlik ve Bilim</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Services / Category Grid -->
		<section class="services" id="hizmetler">
			<div class="container">
				<div class="section-header">
					<h2 class="font-outfit">Uzmanlık Alanları</h2>
					<p>Her yaştan kadın için bilimsel temelli, güvenilir ve güncel sağlık hizmetleri.</p>
				</div>
				<div class="category-grid">
					<CategoryCard 
						href="/category/gebelik-dogum/" 
						title="Gebelik & Doğum" 
						description="Hafta hafta gebelik takibi ve modern doğum yöntemleri."
						image={imgGebelik.src}
						count={303}
					/>
					<CategoryCard 
						href="/category/jinekoloji/" 
						title="Jinekoloji" 
						description="Rutin kontroller, HPV takibi ve kadın sağlığı çözümleri."
						image={imgJinekoloji.src}
						count={235}
					/>
					<CategoryCard 
						href="/category/tup-bebek-infertilite/" 
						title="Tüp Bebek & İnfertilite" 
						description="Üreme sağlığı ve modern tüp bebek teknolojileri."
						image={imgTupBebek.src}
						count={51}
					/>
					<CategoryCard 
						href="/category/cerrahi-islemler/" 
						title="Cerrahi İşlemler" 
						description="Laparoskopik ve minimal invaziv cerrahi teknikler."
						image={imgCerrahi.src}
						count={5}
					/>
					<CategoryCard 
						href="/category/estetik-jinekoloji/" 
						title="Estetik Jinekoloji" 
						description="Lazer uygulamaları ve genital estetik çözümleri."
						image={imgEstetik.src}
						count={3}
					/>
				</div>
			</div>
		</section>

		<!-- Features / Klinik Yaklaşım -->
		<section class="features">
			<div class="container">
				<div class="section-header">
					<h2 class="font-outfit">Hizmet İlkelerimiz ve Klinik Yaklaşımımız</h2>
					<p>Tıbbi etik değerlere ve bilimsel kanıtlara dayalı hasta odaklı yaklaşımımız.</p>
				</div>
				<div class="features-grid">
					<div class="feature-item glass">
						<div class="feature-icon">🔬</div>
						<h3>Kişiye Özel Planlama</h3>
						<p>Her hastanın tıbbi geçmişi ve mevcut durumu detaylıca incelenerek kişiye özel tanı ve takip süreçleri planlanır.</p>
					</div>
					<div class="feature-item glass">
						<div class="feature-icon">📡</div>
						<h3>Tıbbi Donanım ve Altyapı</h3>
						<p>Klinik uygulamalarımızda ve cerrahi süreçlerde modern tıbbi yöntemler ve güncel teknolojik altyapı kullanılır.</p>
					</div>
					<div class="feature-item glass">
						<div class="feature-icon">🛡️</div>
						<h3>Etik ve Şeffaf Bilgilendirme</h3>
						<p>Tanı ve tedavi süreçlerinde hastalarımıza güncel bilimsel veriler ışığında, şeffaf ve anlaşılır bilgilendirme sağlanır.</p>
					</div>
					<div class="feature-item glass">
						<div class="feature-icon">🏙️</div>
						<h3>Lokasyon ve Ulaşım</h3>
						<p>İstanbul'un merkezi noktalarından Nişantaşı'nda, ulaşım ağlarına yakın konumda hastalarımıza hizmet sunmaktayız.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Clinic Highlights / Gallery -->
		<section class="clinic-gallery">
			<div class="container">
				<div class="gallery-layout">
					<div class="gallery-text">
						<h2 class="font-outfit">Modern & Konforlu <br/><span class="text-gradient">Klinik Ortamı</span></h2>
						<p>Sizleri Nişantaşı'nın kalbinde, huzurlu ve modern bir atmosferde ağırlıyoruz. En son teknoloji cihazlar ve konforunuz için tasarlanmış muayene odalarımızla hizmetinizdeyiz.</p>
						<ul class="gallery-features">
							<li>✨ Ferah Bekleme Alanı</li>
							<li>🛡️ Hijyenik Muayene Odaları</li>
							<li>🚇 Kolay Metro Erişimi</li>
						</ul>
					</div>
					<div class="gallery-visual">
						<div class="gallery-img-grid">
							<div class="gallery-img-item tall">
								<img src={clinicEntrance.src} alt="Lotus Nişantaşı - Klinik Ana Girişi" />
							</div>
							<div class="gallery-img-item">
								<img src={clinicCorridor.src} alt="Modern Klinik Koridoru ve Alışveriş Alanı" />
							</div>
							<div class="gallery-img-item">
								<img src={clinicConsultation.src} alt="Dr. Alper Mumcu ile Yüz Yüze Görüşme ve Danışmanlık" />
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Doctor Profile Section -->
		<section class="doctor-profile">
			<div class="container">
				<div class="profile-card glass">
					<div class="profile-content">
						<h2 class="font-outfit">Dr. Alper Mumcu</h2>
						<p class="subtitle">Kadın Hastalıkları ve Doğum Uzmanı</p>
						<p class="bio">
							1998 yılından bu yana kadın sağlığı, riskli gebelik takibi ve tüp bebek alanlarında binlerce hastaya hizmet vermiş olan Dr. Alper Mumcu, Lotus Nişantaşı'ndaki kliniğinde modern tıbbın tüm imkanlarını hastalarıyla buluşturmaktadır.
						</p>
						<div class="affiliations">
							<strong>Üyelikler & Bağlantılar:</strong>
							<div class="affiliation-logos">
								<span>TJOD</span>
								<span>TSRM</span>
								<span>ESHRE</span>
								<span>ASRM</span>
							</div>
						</div>
						<a href="/dr-alper-mumcu" class="btn btn-outline">Hakkımda Daha Fazla Bilgi</a>
					</div>
					<div class="profile-image-container">
						<div class="image-accent"></div>
						<div class="profile-image">
							<img src={doctorPhoto.src} alt="Dr. Alper Mumcu" class="doctor-img" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ Section -->
		<section class="faq-section">
			<div class="container">
				<div class="section-header">
					<h2 class="font-outfit">Sıkça Sorulan Sorular</h2>
					<p>Muayene süreci ve merak ettiğiniz genel konular.</p>
				</div>
				<FAQAccordion items={faqItems} />
			</div>
		</section>

		<!-- Latest Blog Posts -->
		<section class="blog-preview">
			<div class="container glass blog-container">
				<div class="section-header">
					<h2 class="font-outfit">Bilgi Kütüphanesi</h2>
					<p>Kadın sağlığı ve hamilelik üzerine en güncel paylaşımlar.</p>
				</div>
				<div class="grid">
					{posts.map((post) => (
						<article class="post-card">
							<div class="post-image">
								<img src={getHeroImage(post.slug, (post.data.category || [])[0], post.data.heroImage)} alt={post.data.title} loading="lazy" />
							</div>
							<div class="post-content">
								<div class="post-meta">
									<span class="post-date">{post.data.pubDate.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric'})}</span>
									<span class="post-cat">{(post.data.category || [])[0]}</span>
								</div>
								<h3>{post.data.title}</h3>
								<a href={`/blog/${post.slug}/`} class="more-link">Devamını Oku &rarr;</a>
							</div>
						</article>
					))}
				</div>
				<div class="view-all">
					<a href="/blog/" class="btn btn-primary">Tüm Kütüphaneyi Keşfet</a>
				</div>
			</div>
		</section>

		<PregnancyCalculator />
	</main>
</Layout>

<style>
	/* Hero Section */
	.hero {
		min-height: 90vh;
		display: flex;
		align-items: center;
		padding: 8rem 0 4rem;
		position: relative;
		overflow: hidden;
		background: 
			radial-gradient(ellipse 60% 50% at 10% 20%, hsl(var(--accent) / 0.05), transparent),
			radial-gradient(ellipse 50% 50% at 90% 80%, hsl(190 60% 40% / 0.03), transparent),
			hsl(var(--bg-main));
	}

	.hero-bg-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		z-index: 1;
		pointer-events: none;
		opacity: 0.4;
	}
	.hero-bg-orb--1 {
		width: 400px;
		height: 400px;
		top: -100px;
		right: -50px;
		background: radial-gradient(circle, hsl(var(--accent) / 0.15), transparent 70%);
		animation: orbFloat 20s infinite alternate;
	}
	.hero-bg-orb--2 {
		width: 300px;
		height: 300px;
		bottom: 10%;
		left: -50px;
		background: radial-gradient(circle, hsl(190 70% 30% / 0.1), transparent 70%);
		animation: orbFloat 25s infinite alternate-reverse;
	}

	@keyframes orbFloat {
		from { transform: translate(0, 0) rotate(0deg); }
		to { transform: translate(40px, -30px) rotate(10deg); }
	}

	.hero-content {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 5rem;
		align-items: center;
		position: relative;
		z-index: 2;
	}
	.hero-text h1 {
		font-size: 3.75rem;
		line-height: 1.1;
		margin: 1.5rem 0;
		color: hsl(var(--text-main));
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.hero-intro {
		font-size: 1.25rem;
		color: hsl(var(--text-muted));
		margin-bottom: 2rem;
		max-width: 600px;
		line-height: 1.65;
	}

	.trust-badges {
		display: flex;
		gap: 1rem;
		margin-bottom: 0.5rem;
	}
	.trust-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.625rem;
		background: white;
		color: hsl(var(--text-main));
		padding: 0.5rem 1rem;
		border-radius: 99px;
		font-size: 0.82rem;
		font-weight: 700;
		border: 1px solid var(--glass-border);
		box-shadow: var(--shadow-sm);
	}
	.badge-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		display: inline-block;
	}
	.badge-dot.green { background: #22c55e; box-shadow: 0 0 8px #22c55e80; }
	.badge-dot.pink { background: hsl(var(--accent)); box-shadow: 0 0 8px hsl(var(--accent) / 0.4); }
	.badge-dot.blue { background: #3b82f6; box-shadow: 0 0 8px #3b82f680; }

	/* Visual Stack */
	.hero-visual {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.image-stack {
		position: relative;
		width: 100%;
		max-width: 500px;
		z-index: 5;
	}
	.main-image-frame {
		position: relative;
		border-radius: 32px;
		overflow: hidden;
		border: 6px solid white;
		box-shadow: var(--shadow-xl);
		aspect-ratio: 4/5;
		transform: rotate(2deg);
		transition: transform 0.5s ease;
	}
	.main-image-frame:hover {
		transform: rotate(0deg) scale(1.02);
	}
	.hero-img-main {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.image-overlay-gradient {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, hsl(var(--primary) / 0.2), transparent);
		pointer-events: none;
	}

	/* Floating Boxes */
	.floating-box {
		position: absolute;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(12px);
		border: 1px solid var(--glass-border);
		border-radius: 20px;
		padding: 1rem 1.25rem;
		display: flex;
		align-items: center;
		gap: 0.875rem;
		box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
		z-index: 10;
		animation: float 4s infinite alternate ease-in-out;
	}
	.stat-icon {
		font-size: 1.5rem;
		background: hsl(var(--bg-main));
		width: 44px;
		height: 44px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.stat-info strong {
		display: block;
		font-size: 1.15rem;
		font-weight: 800;
		color: hsl(var(--text-main));
		line-height: 1.1;
	}
	.stat-info span {
		font-size: 0.75rem;
		font-weight: 700;
		color: hsl(var(--text-muted));
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.stat-experience { top: 10%; left: -15%; animation-delay: 0s; }
	.stat-babies { bottom: 15%; right: -10%; animation-delay: -1s; }
	.stat-articles { top: 60%; left: -20%; animation-delay: -2s; }

	@keyframes float {
		from { transform: translateY(0); }
		to { transform: translateY(-10px); }
	}

	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.blob {
		position: absolute;
		width: 450px;
		height: 450px;
		background: var(--accent-gradient);
		filter: blur(100px);
		border-radius: 50%;
		opacity: 0.15;
		animation: drift 15s infinite alternate ease-in-out;
	}

	/* Grid Layouts */
	.category-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
		gap: 2rem;
	}

	/* Section Headers */
	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}
	.section-header h2 {
		font-size: 3rem;
		margin-bottom: 1rem;
		color: hsl(var(--text-main));
		font-weight: 800;
	}
	.section-header p {
		color: hsl(var(--text-muted));
		font-size: 1.2rem;
		max-width: 600px;
		margin: 0 auto;
	}

	/* Doctor Profile */
	.doctor-profile {
		padding: 100px 0;
		background: hsl(var(--accent) / 0.02);
	}
	.profile-card {
		display: grid;
		grid-template-columns: 1fr 350px;
		gap: 3rem;
		padding: 4rem;
		border-radius: 40px;
		align-items: center;
	}
	.profile-content h2 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}
	.subtitle {
		color: hsl(var(--accent));
		font-weight: 700;
		font-size: 1.1rem;
		margin-bottom: 1.5rem;
	}
	.bio {
		font-size: 1.15rem;
		line-height: 1.7;
		margin-bottom: 2rem;
		color: hsl(var(--text-muted));
	}
	.affiliations {
		margin-bottom: 2.5rem;
	}
	.affiliation-logos {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}
	.affiliation-logos span {
		background: white;
		padding: 0.4rem 0.8rem;
		border-radius: 8px;
		font-size: 0.8rem;
		font-weight: 800;
		border: 1px solid var(--glass-border);
		color: hsl(var(--text-muted));
	}
	.profile-image-container {
		position: relative;
		height: 450px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.image-accent {
		position: absolute;
		width: 110%;
		height: 110%;
		background: linear-gradient(135deg, hsl(var(--accent) / 0.1), transparent);
		border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
		animation: morph 8s ease-in-out infinite;
		z-index: 1;
	}
	.profile-image {
		position: relative;
		z-index: 2;
		width: 350px;
		height: 450px;
		overflow: hidden;
		border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
		box-shadow: var(--shadow-xl);
		border: 4px solid white;
		background: white;
	}
	.doctor-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top;
		transition: transform 0.5s ease;
	}
	.profile-image:hover .doctor-img {
		transform: scale(1.05);
	}

	@keyframes morph {
		0% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
		50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
		100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
	}

	/* FAQ Section */
	.faq-section {
		padding: 100px 0;
	}

	/* Blog Preview */
	.post-card {
		background: white;
		border-radius: 20px;
		transition: all 0.3s ease;
		border: 1px solid var(--glass-border);
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}
	.post-image {
		height: 180px;
		width: 100%;
		overflow: hidden;
		background: hsl(var(--secondary) / 0.3);
	}
	.post-image img {
		width: 100%;
