---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
---

<Layout title="Alper Mumcu | Kişisel Web Sitesi">
	<main>
		<svg
			class="astro-a"
			width="495"
			height="623"
			viewBox="0 0 495 623"
			fill="none"
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
		>
			<path
				fill-rule="evenodd"
				clip-rule="evenodd"
				d="M167.19 158.16C188.83 158.16 206.39 175.72 206.39 197.36V287.39C206.39 309.03 188.83 326.59 167.19 326.59C145.55 326.59 127.99 309.03 127.99 287.39V197.36C127.99 175.72 145.55 158.16 167.19 158.16Z"
				fill="url(#paint0_linear_1805_24383)"
			/>
			<path
				fill-rule="evenodd"
				clip-rule="evenodd"
				d="M327.81 158.16C349.45 158.16 367.01 175.72 367.01 197.36V287.39C367.01 309.03 349.45 326.59 327.81 326.59C306.17 326.59 288.61 309.03 288.61 287.39V197.36C288.61 175.72 306.17 158.16 327.81 158.16Z"
				fill="url(#paint1_linear_1805_24383)"
			/>
			<path
				fill-rule="evenodd"
				clip-rule="evenodd"
				d="M247.5 352.75C269.14 352.75 286.7 370.31 286.7 391.95V481.98C286.7 503.62 269.14 521.18 247.5 521.18C225.86 521.18 208.3 503.62 208.3 481.98V391.95C208.3 370.31 225.86 352.75 247.5 352.75Z"
				fill="url(#paint2_linear_1805_24383)"
			/>
			<defs>
				<linearGradient
					id="paint0_linear_1805_24383"
					x1="167.19"
					y1="158.16"
					x2="167.19"
					y2="326.59"
					gradientUnits="userSpaceOnUse"
				>
					<stop stop-color="#4F39FA" />
					<stop offset="1" stop-color="#DA62C4" />
				</linearGradient>
				<linearGradient
					id="paint1_linear_1805_24383"
					x1="327.81"
					y1="158.16"
					x2="327.81"
					y2="326.59"
					gradientUnits="userSpaceOnUse"
				>
					<stop stop-color="#4F39FA" />
					<stop offset="1" stop-color="#DA62C4" />
				</linearGradient>
				<linearGradient
					id="paint2_linear_1805_24383"
					x1="247.5"
					y1="352.75"
					x2="247.5"
					y2="521.18"
					gradientUnits="userSpaceOnUse"
				>
					<stop stop-color="#4F39FA" />
					<stop offset="1" stop-color="#DA62C4" />
				</linearGradient>
			</defs>
		</svg>
		<h1>Hoş Geldiniz, <span class="text-gradient">Alper Mumcu</span></h1>
		<p class="instructions">
			Bu site <strong>Astro</strong> ile güçlendirilmiş kişisel dijital kartvizitinizdir.<br />
			Modern, hızlı ve estetik bir deneyim sunar.
		</p>
		<ul role="list" class="link-card-grid">
			<Card
				href="https://github.com/alpermumcu"
				title="GitHub"
				body="Projelerimi ve kodlarımı inceleyin."
			/>
			<Card
				href="https://linkedin.com/in/alpermumcu"
				title="LinkedIn"
				body="Profesyonel ağım ile bağlantı kurun."
			/>
			<Card
				href="mailto:alper@mumcu.com"
				title="İletişim"
				body="Benimle e-posta yoluyla iletişime geçin."
			/>
			<Card
				href="https://astro.build/chat/"
				title="Topluluk"
				body="Astro topluluğuna katılın ve öğrenin."
			/>
		</ul>
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.6;
		position: relative;
		z-index: 1;
	}
	.astro-a {
		position: absolute;
		top: -32px;
		left: 50%;
		transform: translatex(-50%);
		width: 220px;
		height: auto;
		z-index: -1;
		opacity: 0.5;
		filter: blur(40px);
	}
	h1 {
		font-size: 4rem;
		font-weight: 800;
		line-height: 1;
		text-align: center;
		margin-bottom: 1em;
		margin-top: 2rem;
	}
	.text-gradient {
		background-image: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 400%;
		background-position: 0%;
	}
	.instructions {
		margin-bottom: 2rem;
		border: 1px solid rgba(var(--accent-light), 25%);
		background: linear-gradient(rgba(var(--accent-dark), 66%), rgba(var(--accent-dark), 33%));
		padding: 1.5rem;
		border-radius: 12px;
		text-align: center;
		box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
	}
	.instructions code {
		font-size: 0.8em;
		font-weight: bold;
		background: rgba(var(--accent-light), 12%);
		color: rgb(var(--accent-light));
		border-radius: 4px;
		padding: 0.3em 0.45em;
	}
	.instructions strong {
		color: rgb(var(--accent-light));
	}
	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
		gap: 2rem;
		padding: 0;
	}
</style>
