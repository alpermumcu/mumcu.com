---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<Layout title="Dr. Alper Mumcu | Kadın Hastalıkları ve Doğum Uzmanı">
	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="container hero-content">
				<div class="hero-text">
					<span class="badge">Kadın Hastalıkları ve Doğum Uzmanı</span>
					<h1>Modern Yaklaşımla <br/><span class="text-gradient">Kadın Sağlığı Bilgisi</span></h1>
					<p>Dr. Alper Mumcu'nun 25 yılı aşkın tecrübesiyle hazırlanan, güncel ve bilimsel kadın sağlığı platformuna hoş geldiniz.</p>
					<div class="hero-actions">
						<a href="/online-randevu" class="btn btn-primary">Randevu Al</a>
						<a href="/dr-alper-mumcu" class="btn btn-outline">Hakkında</a>
					</div>
				</div>
				<div class="hero-decoration">
					<div class="blob"></div>
				</div>
			</div>
		</section>

		<!-- Services Grid -->
		<section class="services">
			<div class="container">
				<div class="section-header">
					<h2 class="font-outfit">Hizmet Alanları</h2>
					<p>Size özel uzmanlık alanlarımız ve bilgilendirici içeriklerimiz.</p>
				</div>
				<div class="grid">
					<Card 
						href="/hamilelik/" 
						title="Hamilelik" 
						body="Hafta hafta gebelik takibi, beslenme ve merak edilen her şey."
					/>
					<Card 
						href="/dogum/" 
						title="Doğum" 
						body="Doğum yöntemleri, hazırlık süreci ve sonrası için rehber bilgiler."
					/>
					<Card 
						href="/jinekoloji/" 
						title="Jinekoloji" 
						body="Genel kadın sağlığı, cerrahi işlemler ve güncel yaklaşımlar."
					/>
					<Card 
						href="/infertilite/" 
						title="İnfertilite" 
						body="Kısırlık tedavisi, tüp bebek süreçleri ve yeni teknolojiler."
					/>
				</div>
			</div>
		</section>

		<!-- Latest Blog Posts -->
		<section class="blog-preview">
			<div class="container glass blog-container">
				<div class="section-header">
					<h2 class="font-outfit">Son Makaleler</h2>
					<p>Kadın sağlığı ve hamilelik üzerine en güncel paylaşımlar.</p>
				</div>
				<div class="grid">
					{posts.map((post) => (
						<article class="post-card">
							<div class="post-date">{post.data.pubDate.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric'})}</div>
							<h3>{post.data.title}</h3>
							<a href={`/blog/${post.slug}/`} class="more-link">Devamını Oku &rarr;</a>
						</article>
					))}
				</div>
				<div class="view-all">
					<a href="/blog/" class="btn btn-outline">Tüm Blog Yazılarını Gör</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* Hero Section */
	.hero {
		min-height: 80vh;
		display: flex;
		align-items: center;
		padding-top: 8rem;
		background: radial-gradient(circle at 10% 20%, hsl(var(--accent) / 0.1), transparent 40%);
	}
	.hero-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	.hero-text h1 {
		font-size: 4.5rem;
		line-height: 1.1;
		margin: 1.5rem 0;
	}
	.hero-text p {
		font-size: 1.25rem;
		color: hsl(var(--text-muted));
		margin-bottom: 2.5rem;
		max-width: 500px;
	}
	.badge {
		background: hsl(var(--accent) / 0.15);
		color: hsl(var(--accent-light));
		padding: 0.5rem 1rem;
		border-radius: 99px;
		font-size: 0.875rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	/* Buttons */
	.hero-actions {
		display: flex;
		gap: 1.5rem;
	}
	.btn {
		padding: 1rem 2rem;
		border-radius: 12px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
		display: inline-block;
	}
	.btn-primary {
		background: var(--accent-gradient);
		color: white;
		box-shadow: 0 10px 20px -5px hsl(var(--accent) / 0.4);
	}
	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 15px 25px -5px hsl(var(--accent) / 0.5);
	}
	.btn-outline {
		border: 1px solid var(--glass-border);
		background: var(--glass);
		color: white;
		backdrop-filter: blur(8px);
	}
	.btn-outline:hover {
		background: var(--glass-border);
		transform: translateY(-2px);
	}

	/* Decoration */
	.hero-decoration {
		position: relative;
		height: 400px;
	}
	.blob {
		position: absolute;
		width: 300px;
		height: 300px;
		background: var(--accent-gradient);
		filter: blur(80px);
		border-radius: 50%;
		opacity: 0.3;
		animation: drift 10s infinite alternate ease-in-out;
	}
	@keyframes drift {
		from { transform: translate(0, 0); }
		to { transform: translate(50px, 30px); }
	}

	/* Sections */
	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}
	.section-header h2 {
		font-size: 3rem;
		margin-bottom: 1rem;
	}
	.section-header p {
		color: hsl(var(--text-muted));
		font-size: 1.125rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
	}

	/* Blog Preview */
	.blog-preview {
		padding-bottom: 8rem;
	}
	.blog-container {
		padding: 4rem;
		border-radius: 32px;
	}
	.post-card {
		padding: 1.5rem;
		border-bottom: 1px solid var(--glass-border);
		transition: all 0.3s ease;
	}
	.post-card:hover {
		background: hsl(var(--accent) / 0.05);
	}
	.post-date {
		font-size: 0.8rem;
		color: hsl(var(--accent-light));
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}
	.post-card h3 {
		font-size: 1.25rem;
		margin-bottom: 1rem;
		line-height: 1.4;
	}
	.more-link {
		color: hsl(var(--accent));
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9rem;
	}
	.view-all {
		text-align: center;
		margin-top: 3rem;
	}

	@media (max-width: 1024px) {
		.hero-content {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-text h1 {
			font-size: 3.5rem;
		}
		.hero-text p {
			margin: 1.5rem auto 2.5rem;
		}
		.hero-actions {
			justify-content: center;
		}
		.hero-decoration {
			display: none;
		}
		.blog-container {
			padding: 2rem;
		}
	}

	@media (max-width: 640px) {
		.hero-text h1 {
			font-size: 2.75rem;
		}
		.section-header h2 {
			font-size: 2.25rem;
		}
	}
</style>
