---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Sidebar from '../components/Sidebar.astro';

export async function getStaticPaths() {
	const pages = await getCollection('pages');
	return pages.map((page) => ({
		params: { slug: page.slug },
		props: page,
	}));
}
type Props = CollectionEntry<'pages'>;

const page = Astro.props;
const { Content } = await page.render();
---

<Layout title={page.data.title}>
  <ReadingProgress />
	<div class="content-wrapper container">
    <article class="post-content">
      <Breadcrumbs 
        parts={[
          { label: page.data.title }
        ]} 
      />
      
			{page.data.heroImage && (
				<Image 
					width={1020} 
					height={510} 
					src={page.data.heroImage} 
					alt={page.data.title} 
					class="hero-img" 
					loading="eager" 
					fetchpriority="high" 
				/>
			)}
			<h1 class="title font-outfit">{page.data.title}</h1>
			
			<div class="prose">
				<Content />
			</div>

      <div class="medical-disclaimer-box glass">
        <div class="disclaimer-header">
          <span class="disclaimer-icon">⚠️</span>
          <strong>Önemli Bilgilendirme</strong>
        </div>
        <p>Sitemizde yer alan tüm içerikler genel bilgilendirme amaçlıdır. Bu içerik, bir doktorun profesyonel tıbbi tavsiyesi, tanısı veya tedavisinin yerini alamaz. Sağlığınızla ilgili her türlü tıbbi sorunuz için lütfen mutlaka doktorunuza danışınız.</p>
      </div>
		</article>
    <Sidebar />
	</div>
</Layout>

<style>
	.content-wrapper {
		margin: 8rem auto 4rem;
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 4rem;
	}
	.post-content {
		background: white;
		border: 1px solid var(--glass-border);
		border-radius: 32px;
		padding: 4rem;
		box-shadow: var(--shadow-sm);
	}
	.title {
		font-size: 3.5rem;
		color: hsl(var(--text-main));
		line-height: 1.1;
		margin: 1.5rem 0 3.5rem;
		font-weight: 800;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--glass-border);
	}
	.prose {
		color: hsl(var(--text-main));
		line-height: 1.8;
		font-size: 1.15rem;
	}
	.prose :global(p) {
		margin-bottom: 2rem;
	}
	.prose :global(h2), .prose :global(h3) {
		color: hsl(var(--text-main));
		margin-top: 4rem;
		margin-bottom: 1.5rem;
		font-family: 'Outfit', sans-serif;
		font-weight: 800;
	}
	.prose :global(h2) { font-size: 2.25rem; }
	.prose :global(h3) { font-size: 1.75rem; }

	.hero-img {
		max-width: 100%;
		height: auto;
		border-radius: 20px;
		margin-bottom: 2rem;
		box-shadow: var(--shadow-md);
	}

	@media (max-width: 1024px) {
		.content-wrapper {
			grid-template-columns: 1fr;
			margin-top: 6rem;
		}
	}
	@media (max-width: 768px) {
		.post-content {
			padding: 2rem;
			border-radius: 24px;
		}
		.title {
			font-size: 2.25rem;
		}
	}

  /* Disclaimer Styling */
  .medical-disclaimer-box {
    margin-top: 5rem;
    padding: 2.5rem;
    border-radius: 20px;
    background: linear-gradient(135deg, hsl(var(--accent) / 0.03), hsl(var(--accent) / 0.01));
    border-left: 5px solid hsl(var(--accent));
    text-align: left;
  }
  .disclaimer-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 1.1rem;
    color: hsl(var(--text-main));
  }
  .disclaimer-icon {
    font-size: 1.25rem;
  }
  .medical-disclaimer-box p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: hsl(var(--text-muted));
  }

  /* KVKK Checkbox Styling */
  .kvkk-notice {
    margin-top: 3rem;
    font-size: 0.9rem;
    color: hsl(var(--text-muted));
    padding: 1.5rem;
    background: hsl(var(--accent) / 0.05);
    border-radius: 20px;
    line-height: 1.5;
    border: 1px solid hsl(var(--accent) / 0.1);
  }

  .kvkk-checkbox-container {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    cursor: pointer;
    user-select: none;
    position: relative;
  }

  .kvkk-checkbox-container input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
  }

  .checkmark {
    min-width: 22px;
    height: 22px;
    background-color: white;
    border: 2px solid hsl(var(--accent) / 0.3);
    border-radius: 6px;
    position: relative;
    transition: all 0.2s ease;
    margin-top: 2px;
  }

  .kvkk-checkbox-container:hover input ~ .checkmark {
    border-color: hsl(var(--accent));
    background-color: hsl(var(--accent) / 0.05);
  }

  .kvkk-checkbox-container input:checked ~ .checkmark {
    background-color: hsl(var(--accent));
    border-color: hsl(var(--accent));
  }

  .checkmark:after {
    content: "";
    position: absolute;
    display: none;
  }

  .kvkk-checkbox-container input:checked ~ .checkmark:after {
    display: block;
  }

  .kvkk-checkbox-container .checkmark:after {
    left: 7px;
    top: 3px;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .kvkk-text {
    font-size: 0.95rem;
  }

  .kvkk-text a {
    color: hsl(var(--accent));
    font-weight: 600;
    text-decoration: underline;
  }
</style>
