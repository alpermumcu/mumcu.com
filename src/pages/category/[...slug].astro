---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/categories';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	
	const paths = [
		...categories.map((cat) => ({
			params: { slug: cat.slug },
			props: { categoryName: cat.name },
		})),
		{ params: { slug: 'hamilelik/hafta-hafta-gebelik' }, props: { categoryName: 'Hafta Hafta Gebelik' } },
		{ params: { slug: 'hamilelik/hamilelik-haberleri' }, props: { categoryName: 'Haberler | Hamilelik' } },
		{ params: { slug: 'infertilite/tup-bebek-haber' }, props: { categoryName: 'Tüp Bebek Haber' } },
	];

	return paths;
}

const { slug } = Astro.params;
const { categoryName } = Astro.props;

const categoryPosts = (await getCollection('blog'))
	.filter((post) => post.data.category?.includes(categoryName))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={categoryName}>
	<div class="content-wrapper container">
    <main class="category-content">
      <Breadcrumbs parts={[{ label: categoryName }]} />
      <header class="category-header">
        <h1 class="text-gradient">{categoryName}</h1>
        <p class="subtitle">"{categoryName}" kategorisindeki tüm yazılar.</p>
      </header>

      <div class="posts-grid">
        {categoryPosts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="post-card glass">
            <div class="post-card-content">
              <h3>{post.data.title} &rarr;</h3>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('tr-TR', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </div>
          </a>
        ))}
      </div>
    </main>

    <Sidebar />
  </div>
</Layout>

<style>
  .content-wrapper {
    margin: 8rem auto 4rem;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
  }
	.category-header {
		margin-bottom: 4rem;
	}
	h1 {
		font-size: 3.5rem;
		margin-bottom: 1.5rem;
    font-weight: 800;
	}
	.subtitle {
		color: hsl(var(--text-muted));
		font-size: 1.25rem;
    max-width: 600px;
    line-height: 1.6;
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2.5rem;
	}
	.post-card {
		padding: 2.5rem;
		text-decoration: none;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		border-radius: 32px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		background: white;
		box-shadow: var(--shadow-sm);
		border: 1px solid var(--glass-border);
	}
	.post-card:hover {
		transform: translateY(-8px);
		box-shadow: var(--shadow-md);
		border-color: hsl(var(--accent) / 0.3);
	}
	.post-card h3 {
		color: hsl(var(--text-main));
		font-size: 1.6rem;
		margin-bottom: 2rem;
		line-height: 1.4;
		font-family: 'Outfit', sans-serif;
		font-weight: 800;
	}
	time {
		color: hsl(var(--accent));
		font-size: 0.9rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

  @media (max-width: 1024px) {
    .content-wrapper {
      grid-template-columns: 1fr;
      margin-top: 6rem;
    }
  }
	@media (max-width: 768px) {
    .post-card {
      padding: 2rem;
    }
		h1 {
			font-size: 2.5rem;
		}
    .posts-grid {
      grid-template-columns: 1fr;
    }
	}
</style>

