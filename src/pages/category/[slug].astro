---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { categories } from '../../data/categories';
import { getHeroImage } from '../../data/category-defaults';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return categories.map((category) => {
    const filteredPosts = posts.filter((post) => 
      post.data.category?.includes(category.name)
    ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    
    return {
      params: { slug: category.slug },
      props: { category, posts: filteredPosts },
    };
  });
}

const { category, posts } = Astro.props;
---

<Layout title={`${category.name} | Dr. Alper Mumcu`}>
  <div class="content-wrapper container">
    <main class="category-main">
      <Breadcrumbs 
        parts={[
          { label: 'Bilgi Kütüphanesi', href: '/blog/' },
          { label: category.name }
        ]} 
      />
      
      <header class="category-header">
        <h1 class="font-outfit">{category.name}</h1>
        <p>{posts.length} Uzman Makalesi</p>
      </header>

      <div class="posts-grid">
        {posts.map((post) => (
          <article class="post-card">
            <div class="post-image">
              <img 
                src={getHeroImage(post.slug, (post.data.category || [])[0], post.data.heroImage)} 
                alt={post.data.title} 
                loading="lazy" 
              />
            </div>
            <div class="post-content">
              <div class="meta">
                <span>{post.data.pubDate.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                <span>⏱️ {post.data.readingTime} dk</span>
              </div>
              <h3>{post.data.title}</h3>
              <a href={`/blog/${post.slug}/`} class="btn-text">Okumaya Devam Et →</a>
            </div>
          </article>
        ))}
      </div>
    </main>
    <Sidebar />
  </div>
</Layout>

<style>
  .content-wrapper {
    margin: 8rem auto 4rem;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
  }
  .category-header {
    margin: 2rem 0 4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--glass-border);
  }
  h1 {
    font-size: 3.5rem;
    color: hsl(var(--text-main));
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .category-header p {
    font-size: 1.25rem;
    color: hsl(var(--accent));
    font-weight: 700;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .post-card {
    background: white;
    border-radius: 20px;
    transition: all 0.3s ease;
    border: 1px solid var(--glass-border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .post-image {
    height: 140px;
    width: 100%;
    overflow: hidden;
    background: hsl(var(--secondary) / 0.3);
  }
  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .post-card:hover .post-image img {
    transform: scale(1.1);
  }
  .post-content {
    padding: 1rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .post-card:hover {
    transform: translateY(-5px);
    border-color: hsl(var(--accent) / 0.3);
  }
  .meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    font-weight: 700;
    color: hsl(var(--text-muted));
    margin-bottom: 1rem;
  }
  h3 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
    color: hsl(var(--text-main));
    font-family: 'Outfit', sans-serif;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .btn-text {
    color: hsl(var(--accent));
    text-decoration: none;
    font-weight: 800;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    position: relative;
    width: fit-content;
    margin-top: 1rem;
  }
  .btn-text::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: hsl(var(--accent));
    transition: width 0.3s ease;
  }
  .btn-text:hover {
    gap: 0.75rem;
    color: hsl(var(--accent) / 0.8);
  }
  .btn-text:hover::after {
    width: 100%;
  }
  @media (max-width: 1024px) {
    .content-wrapper { grid-template-columns: 1fr; margin-top: 6rem; }
  }
</style>
