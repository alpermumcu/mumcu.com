---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getHeroImage } from '../../data/category-defaults';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Tüm Makaleler | Makale Arşivi">
	<main class="container">
		<Breadcrumbs 
			parts={[
				{ label: 'Makale Arşivi', href: '/blog/' },
				{ label: 'Tüm Makaleler' }
			]} 
		/>
		
		<header class="all-header">
			<h1 class="font-outfit">Tüm Makale Arşivi</h1>
			<p>{posts.length} Uzman Makalesi</p>
		</header>

		<div class="posts-list">
			{posts.map((post) => (
				<a href={`/blog/${post.slug}/`} class="post-item glass">
					<div class="item-thumb">
						<img src={getHeroImage(post.slug, (post.data.category || [])[0], post.data.heroImage)} alt="" loading="lazy" />
					</div>
					<div class="item-meta">
						<span class="cat">{post.data.category?.[0]}</span>
						<span class="date">{post.data.pubDate.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
					</div>
					<div class="item-title">
						<h3>{post.data.title}</h3>
						<span class="time">⏱️ {post.data.readingTime} dk okuma</span>
					</div>
				</a>
			))}
		</div>
	</main>
</Layout>

<style>
	main {
		padding: 8rem 1rem 4rem;
	}
	.all-header {
		margin: 2rem 0 4rem;
		text-align: center;
	}
	h1 {
		font-size: 3.5rem;
		color: hsl(var(--text-main));
		font-weight: 800;
	}
	.all-header p {
		font-size: 1.25rem;
		color: hsl(var(--accent));
		font-weight: 700;
	}
	.posts-list {
		display: grid;
		gap: 1rem;
		max-width: 900px;
		margin: 0 auto;
	}
	.post-item {
		display: grid;
		grid-template-columns: 80px 150px 1fr;
		align-items: center;
		padding: 1rem 1.5rem;
		border-radius: 16px;
		text-decoration: none;
		transition: all 0.3s ease;
		gap: 2rem;
		background: white;
		border: 1px solid var(--glass-border);
	}
	.post-item:hover {
		transform: translateX(10px);
		border-color: hsl(var(--accent) / 0.3);
		background: hsl(var(--secondary) / 0.05);
	}
	.item-thumb {
		width: 80px;
		height: 60px;
		border-radius: 8px;
		overflow: hidden;
		background: hsl(var(--secondary) / 0.2);
	}
	.item-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.item-meta {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.cat {
		font-size: 0.75rem;
		font-weight: 800;
		color: hsl(var(--accent));
		text-transform: uppercase;
	}
	.date {
		font-size: 0.8rem;
		color: hsl(var(--text-muted));
	}
	.item-title {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	h3 {
		font-size: 1.15rem;
		margin: 0;
		color: hsl(var(--text-main));
		font-family: 'Outfit', sans-serif;
	}
	.time {
		font-size: 0.85rem;
		color: hsl(var(--text-muted));
	}

	@media (max-width: 768px) {
		.post-item {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}
		.time { text-align: left; margin-top: 0.5rem; }
	}
</style>
