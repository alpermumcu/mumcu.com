---
import { type CollectionEntry, getCollection } from 'astro:content';
import PregnancyPostLayout from '../../layouts/PregnancyPostLayout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('hafta-hafta-gebelik');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'hafta-hafta-gebelik'>;

const post = Astro.props;
const { Content } = await post.render();
---

<PregnancyPostLayout frontmatter={post.data}>
  <Content />
</PregnancyPostLayout>
