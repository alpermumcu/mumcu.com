---
interface Props {
	title: string;
	body: string;
	href: string;
}

const { href, title, body } = Astro.props;
---

<li class="link-card">
	<a href={href}>
		<h2>
			{title}
			<span>&rarr;</span>
		</h2>
		<p>
			{body}
		</p>
	</a>
</li>
<style>
	.link-card {
		list-style: none;
		display: flex;
		padding: 1px;
		background: var(--glass-border);
		border-radius: 16px;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		overflow: hidden;
	}
	.link-card > a {
		width: 100%;
		text-decoration: none;
		line-height: 1.4;
		padding: 2rem;
		border-radius: 15px;
		color: hsl(var(--text-main));
		background: hsl(var(--bg-card));
		transition: background 0.3s ease;
	}
	h2 {
		margin: 0;
		font-size: 1.5rem;
		font-family: 'Outfit', sans-serif;
		color: hsl(var(--text-main));
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	p {
		margin-top: 1rem;
		margin-bottom: 0;
		color: hsl(var(--text-muted));
		font-size: 1rem;
	}
	.link-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
		background: var(--accent-gradient);
	}
	.link-card:hover a {
		background: hsl(var(--bg-card) / 0.8);
	}
	.link-card:hover h2 {
		color: hsl(var(--accent-light));
	}
</style>
