---
---

<section class="ultimate-calculator py-28 px-4 relative overflow-hidden bg-white" id="hesaplayici">
  {/* Advanced SVG Particle Background */}
  <div class="absolute inset-0 pointer-events-none opacity-40">
    <div class="particle-container absolute inset-0"></div>
    <div class="absolute -top-40 -left-20 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[150px] animate-pulse"></div>
    <div class="absolute -bottom-40 -right-20 w-[600px] h-[600px] bg-secondary/5 rounded-full blur-[150px]"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-3 py-2 px-5 rounded-full bg-slate-50 border border-slate-100 mb-6 group cursor-default">
        <span class="w-2 h-2 rounded-full bg-primary animate-ping"></span>
        <span class="text-[10px] font-black uppercase tracking-[0.25em] text-slate-400 group-hover:text-primary transition-colors">Digital Health Lab</span>
      </div>
      <h2 class="text-5xl md:text-6xl font-display font-black text-gray-900 mb-8 tracking-tight leading-[1.1]">
        Büyüleyici Bir Yolculuk:<br/>
        <span class="text-gradient">Tahmini Doğum Takvimi</span>
      </h2>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto font-medium leading-relaxed">
        Bebeğinizin gelişim basamaklarını ve kavuşacağınız günü <br class="hidden md:block"/> en zarif detaylarıyla keşfedin.
      </p>
    </div>

    <div class="grid lg:grid-cols-12 gap-12 items-stretch">
      {/* Input Module */}
      <div class="lg:col-span-4 flex flex-col">
        <div class="premium-glass p-10 rounded-[2.5rem] border border-white bg-white/40 backdrop-blur-3xl shadow-2xl shadow-primary/5 flex-grow">
          <div class="mb-10">
            <label for="lmp-date" class="block text-[11px] font-black text-primary uppercase tracking-[0.2em] mb-6">
              Son Adet Başlangıç Tarihi
            </label>
            <div class="relative group">
              <input 
                type="date" 
                id="lmp-date" 
                class="w-full h-20 px-8 rounded-3xl border-2 border-slate-100 bg-white shadow-inner focus:border-primary focus:ring-[15px] focus:ring-primary/5 outline-none transition-all text-2xl font-black text-gray-800"
              />
              <div class="absolute right-6 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-primary transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
            </div>
          </div>

          <button 
            id="calculate-btn"
            class="w-full h-20 bg-gray-950 text-white font-black rounded-3xl shadow-2xl shadow-gray-950/20 hover:bg-primary hover:-translate-y-2 active:scale-95 transition-all duration-500 overflow-hidden relative group"
          >
            <span class="relative z-10 text-xl tracking-tight">Hesaplamayı Başlat</span>
            <div class="absolute inset-0 bg-primary translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-expo"></div>
          </button>
        </div>

        <div class="mt-8 p-8 rounded-[2rem] bg-slate-50 border border-slate-100 group">
          <p class="text-sm text-gray-500 font-medium leading-[1.8] italic group-hover:text-gray-700 transition-colors">
            "Naegele kuralına göre yapılan bu hesaplama standart bir gebelik süresini (280 gün) temel alır. Her bebek ve her gebelik kendine özeldir."
          </p>
        </div>
      </div>

      {/* Dynamic Result Module */}
      <div class="lg:col-span-8">
        <div id="master-panel" class="relative h-full min-h-[580px] rounded-[3rem] bg-slate-50 overflow-hidden shadow-inner border border-slate-100 group">
          
          {/* Empty State Art */}
          <div id="empty-view" class="absolute inset-0 flex flex-col items-center justify-center p-20 text-center transition-all duration-1000">
            <div class="relative w-40 h-40 mb-10 flex items-center justify-center">
              <div class="absolute inset-0 bg-primary/10 rounded-full blur-3xl animate-pulse"></div>
              <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-primary opacity-50"><path d="M12 21a9 9 0 0 0 0-18 9 9 0 0 0 0 18z"/><path d="M12 8v4m0 4h.01"/></svg>
            </div>
            <h4 class="text-2xl font-black text-gray-900 mb-4">Bir Tarih Seçin</h4>
            <p class="text-gray-400 max-w-sm mx-auto font-medium">Büyük günü ve bebeğinizin şu anki büyüklüğünü görmek için formu doldurun.</p>
          </div>

          {/* Premium Result View */}
          <div id="result-view" class="hidden opacity-0 p-10 md:p-16 h-full flex flex-col transition-all duration-1000 translate-y-12">
            
            {/* Header: Date & Trimester */}
            <div class="flex flex-wrap items-end justify-between gap-6 mb-16">
              <div class="space-y-2">
                <span class="text-[11px] font-black text-primary uppercase tracking-[0.3em]">Tahmini Kavuşma Günü</span>
                <h3 id="res-date" class="text-5xl md:text-7xl font-display font-black text-gray-950 tracking-tighter"></h3>
              </div>
              <div id="trimester-badge" class="py-3 px-6 rounded-2xl bg-gray-950 text-white text-xs font-black uppercase tracking-[0.2em] shadow-xl shadow-gray-900/10">
                1. Trimester
              </div>
            </div>

            {/* Growth Journey Area */}
            <div class="grid md:grid-cols-2 gap-12 mb-16">
              <div class="growth-card p-10 rounded-[2.5rem] bg-white border border-gray-100 shadow-sm relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-8 text-slate-100 group-hover:text-primary/10 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L9 9H2l5.5 4L5 21l7-5 7 5-2.5-8L22 9h-7l-3-7z"/></svg>
                </div>
                <span class="block text-[11px] font-black text-slate-400 uppercase tracking-widest mb-6">Bebeğiniz Şuan...</span>
                <div class="flex items-center gap-6">
                  <div id="fruit-icon" class="text-5xl">🍒</div>
                  <div>
                    <h4 id="fruit-name" class="text-3xl font-black text-gray-950 mb-1">Bir Kiraz</h4>
                    <p class="text-slate-400 font-medium">büyüklüğünde</p>
                  </div>
                </div>
              </div>

              <div class="stats-card space-y-4">
                <div class="flex items-center justify-between p-6 rounded-2xl bg-white border border-gray-50">
                  <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Hafta Bilgisi</span>
                  <span id="res-weeks" class="text-xl font-black text-gray-950"></span>
                </div>
                <div class="flex items-center justify-between p-6 rounded-2xl bg-white border border-gray-50">
                  <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Kalan Gün</span>
                  <span id="res-days" class="text-xl font-black text-gray-950"></span>
                </div>
              </div>
            </div>

            {/* Visual Timeline */}
            <div class="mt-auto">
              <div class="flex justify-between text-[10px] font-black text-slate-300 uppercase tracking-[0.2em] mb-6">
                <span>Başlangıç</span>
                <span class="text-gray-900">Mevcut Durum</span>
                <span>Doğum</span>
              </div>
              <div class="relative h-6 bg-white rounded-full p-1 shadow-inner border border-slate-100">
                <div id="res-progress" class="h-full bg-gradient-to-r from-primary via-secondary to-primary rounded-full transition-all duration-1000 ease-expo shadow-lg shadow-primary/20" style="width: 10%"></div>
              </div>
            </div>

            <div class="mt-12 flex items-center justify-between">
              <p class="text-[10px] font-black text-slate-300 uppercase tracking-widest">Loki Digital Health System</p>
              <button id="reset-btn" class="flex items-center gap-2 text-primary font-black text-[10px] uppercase tracking-widest hover:gap-4 transition-all">
                Yeni Hesaplama <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .text-gradient {
    background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--secondary)));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .ease-expo {
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }

  .premium-glass {
    box-shadow: 
      0 20px 40px -10px rgba(var(--color-primary-rgb), 0.05),
      0 10px 20px -5px rgba(0,0,0,0.02);
  }

  input[type="date"]::-webkit-calendar-picker-indicator {
    cursor: pointer;
    opacity: 0;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #master-panel {
    background-image: radial-gradient(circle at 2px 2px, rgba(0,0,0,0.02) 1px, transparent 0);
    background-size: 40px 40px;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .growth-card {
    animation: float 6s ease-in-out infinite;
  }
</style>

<script>
  const growthStages = [
    { week: 4, size: 'Bir Haşhaş Tohumu', icon: '🌱' },
    { week: 6, size: 'Bir Mercimek', icon: '🫘' },
    { week: 8, size: 'Bir Ahududu', icon: '🍓' },
    { week: 10, size: 'Bir Zeytin', icon: '🫒' },
    { week: 12, size: 'Bir Misket Limonu', icon: '🍋' },
    { week: 16, size: 'Bir Avokado', icon: '🥑' },
    { week: 20, size: 'Bir Muz', icon: '🍌' },
    { week: 24, size: 'Bir Mısır Koçanı', icon: '🌽' },
    { week: 28, size: 'Bir Patlıcan', icon: '🍆' },
    { week: 32, size: 'Bir Bal Kabağı', icon: '🎃' },
    { week: 36, size: 'Bir Papaya', icon: '🥭' },
    { week: 40, size: 'Bir Karpuz', icon: '🍉' }
  ];

  function setupUltimateCalculator() {
    const lmpInput = document.getElementById('lmp-date') as HTMLInputElement;
    const calculateBtn = document.getElementById('calculate-btn');
    const resetBtn = document.getElementById('reset-btn');
    
    const emptyView = document.getElementById('empty-view');
    const resultView = document.getElementById('result-view');
    
    // UI Elements
    const displayDate = document.getElementById('res-date');
    const displayWeeks = document.getElementById('res-weeks');
    const displayDays = document.getElementById('res-days');
    const displayFruitName = document.getElementById('fruit-name');
    const displayFruitIcon = document.getElementById('fruit-icon');
    const progressBar = document.getElementById('res-progress') as HTMLElement;
    const trimesterBadge = document.getElementById('trimester-badge');

    if (!calculateBtn || !lmpInput) return;

    function getGrowth(weeks: number) {
      return growthStages.filter(s => s.week <= weeks).pop() || growthStages[0];
    }

    calculateBtn.addEventListener('click', () => {
      const val = lmpInput.value;
      if (!val) {
        lmpInput.parentElement?.classList.add('shake');
        setTimeout(() => lmpInput.parentElement?.classList.remove('shake'), 500);
        return;
      }

      const lmp = new Date(val);
      const today = new Date();
      
      // EDD
      const edd = new Date(lmp.getTime() + 280 * 24 * 60 * 60 * 1000);
      
      // Progress
      const diffDays = Math.floor((today.getTime() - lmp.getTime()) / (24 * 60 * 60 * 1000));
      const weeks = Math.floor(diffDays / 7);
      const days = diffDays % 7;
      const progressPercent = Math.min(Math.max((diffDays / 280) * 100, 0), 100);

      // Trimester UI
      let trimText = "1. Trimester";
      if (weeks >= 14) trimText = "2. Trimester";
      if (weeks >= 28) trimText = "3. Trimester";

      // Growth
      const growth = getGrowth(weeks);

      // Render
      if (emptyView && resultView && displayDate && displayWeeks && displayDays && progressBar && displayFruitName && displayFruitIcon) {
        emptyView.classList.add('opacity-0', 'scale-95');
        setTimeout(() => {
          emptyView.classList.add('hidden');
          resultView.classList.remove('hidden');
          setTimeout(() => {
            resultView.classList.remove('opacity-0', 'translate-y-12');
            progressBar.style.width = `${progressPercent}%`;
          }, 50);

          displayDate.innerText = edd.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
          displayWeeks.innerText = `${weeks} Hafta ${days} Gün`;
          displayDays.innerText = `${Math.max(0, 280 - diffDays)} Gün Kaldı`;
          displayFruitName.innerText = growth.size;
          displayFruitIcon.innerText = growth.icon;
          if (trimesterBadge) trimesterBadge.innerText = trimText;
        }, 500);
      }
    });

    resetBtn?.addEventListener('click', () => {
      if (emptyView && resultView) {
        resultView.classList.add('opacity-0', 'translate-y-12');
        setTimeout(() => {
          resultView.classList.add('hidden');
          emptyView.classList.remove('hidden');
          setTimeout(() => emptyView.classList.remove('opacity-0', 'scale-95'), 50);
        }, 500);
      }
    });
  }

  document.addEventListener('astro:page-load', setupUltimateCalculator);
  setupUltimateCalculator();
</script>
