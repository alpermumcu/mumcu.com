---
---

<section class="calculator-section py-24 px-4 relative overflow-hidden bg-white" id="hesaplayici">
  {/* Fluid medical background shapes */}
  <div class="absolute top-0 left-0 w-full h-full opacity-30 pointer-events-none">
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary/10 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute top-1/2 -right-24 w-80 h-80 bg-secondary/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-5xl mx-auto relative z-10">
    <div class="text-center mb-16">
      <span class="inline-block py-1 px-4 rounded-full bg-primary/10 text-primary text-xs font-black uppercase tracking-[0.2em] mb-4">
        Kadın Sağlığı Araçları
      </span>
      <h2 class="text-4xl md:text-5xl font-display font-black text-gray-900 mb-6 tracking-tight">
        Tahmini Doğum Tarihi <span class="text-gradient">Hesaplayıcı</span>
      </h2>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto font-medium">
        Naegele yöntemi ile bebeğinizin tahmini varış tarihini ve şu anki gelişim haftasını keşfedin.
      </p>
    </div>

    <div class="calculator-container grid lg:grid-cols-12 gap-8 items-start">
      {/* Left: Input Panel */}
      <div class="lg:col-span-5 space-y-6">
        <div class="glass-card p-8 rounded-[2rem] border border-white/60 bg-white/60 backdrop-blur-2xl shadow-[0_32px_64px_-16px_rgba(0,0,0,0.08)]">
          <div class="mb-8">
            <label for="lmp-date" class="block text-xs font-black text-primary uppercase tracking-[0.15em] mb-4">
              Son Adet Tarihi (SAT)
            </label>
            <div class="relative">
              <input 
                type="date" 
                id="lmp-date" 
                class="w-full h-16 px-6 rounded-2xl border-2 border-gray-100 bg-white focus:border-primary focus:ring-8 focus:ring-primary/5 outline-none transition-all text-xl font-bold text-gray-800"
              />
            </div>
          </div>

          <button 
            id="calculate-btn"
            class="w-full h-16 bg-primary text-white font-black rounded-2xl shadow-xl shadow-primary/30 hover:shadow-primary/40 hover:-translate-y-1 active:translate-y-0 active:scale-[0.98] transition-all duration-300 flex items-center justify-center gap-4 group"
          >
            <span class="text-lg">Hesaplamayı Başlat</span>
            <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center group-hover:rotate-12 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14m-7-7 7 7-7 7"/>
              </svg>
            </div>
          </button>
        </div>

        <div class="p-6 rounded-2xl bg-secondary/5 border border-secondary/10 flex gap-4 items-start">
          <div class="w-10 h-10 rounded-full bg-secondary/20 flex shrink-0 items-center justify-center text-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="12" cy="12" r="10"/><path d="M12 16v-4m0-4h.01"/>
            </svg>
          </div>
          <p class="text-sm text-gray-600 leading-relaxed italic">
            "Bu araç, tıbbi standartlara göre tahmini bir tarih sunar. Kesin planlama için doktor muayenesi şarttır."
          </p>
        </div>
      </div>

      {/* Right: Rich Result Panel */}
      <div class="lg:col-span-7 h-full">
        <div id="result-panel" class="relative h-full min-h-[460px] rounded-[2rem] overflow-hidden border border-white/60 bg-slate-50 shadow-inner flex flex-col">
          
          {/* Default Empty State */}
          <div id="placeholder-state" class="h-full w-full flex flex-col items-center justify-center p-12 text-center transition-all duration-700">
            <div class="relative mb-8">
              <div class="absolute inset-0 bg-primary/20 blur-3xl rounded-full scale-150 animate-pulse"></div>
              <div class="relative w-24 h-24 bg-white rounded-3xl shadow-xl flex items-center justify-center text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
            </div>
            <h4 class="text-xl font-bold text-gray-800 mb-2">Başlamak için SAT girin</h4>
            <p class="text-gray-500 max-w-xs mx-auto">Tarihi seçip butona bastığınızda detaylı hamilelik takviminiz burada belirecektir.</p>
          </div>

          {/* Active Result State */}
          <div id="result-state" class="hidden opacity-0 h-full w-full p-8 md:p-12 flex flex-col transition-all duration-1000">
            <div class="flex-grow">
              <div class="flex items-center gap-4 mb-8">
                <span class="h-[1px] flex-grow bg-gray-200"></span>
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-400">Tahmini Rapor</span>
                <span class="h-[1px] flex-grow bg-gray-200"></span>
              </div>

              <div class="text-center mb-12">
                <p class="text-primary font-black text-sm uppercase tracking-widest mb-4">Bebeğinizin Beklenen Doğum Tarihi</p>
                <h3 id="res-edd" class="text-5xl md:text-6xl font-display font-black text-gray-900 tracking-tighter"></h3>
              </div>

              {/* Progress Timeline */}
              <div class="mb-12">
                <div class="flex justify-between text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">
                  <span>Başlangıç</span>
                  <span id="res-weeks-label" class="text-secondary">0 Hafta</span>
                  <span>40 Hafta</span>
                </div>
                <div class="relative h-4 bg-gray-100 rounded-full overflow-hidden border border-gray-200/50">
                  <div id="res-progress-bar" class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-secondary transition-all duration-1000 ease-out" style="width: 0%"></div>
                  <div class="absolute top-0 left-1/3 w-[2px] h-full bg-white/40"></div>
                  <div class="absolute top-0 left-2/3 w-[2px] h-full bg-white/40"></div>
                </div>
                <div id="res-trimester-tag" class="mt-4 text-center">
                  <span class="inline-block py-1.5 px-4 rounded-lg bg-gray-900 text-white text-[10px] font-black uppercase tracking-widest">
                    1. Trimester (İlk 3 Ay)
                  </span>
                </div>
              </div>

              {/* Detail Cards */}
              <div class="grid grid-cols-2 gap-4">
                <div class="p-6 rounded-2xl bg-white shadow-sm border border-gray-50">
                  <span class="block text-[10px] font-black text-gray-400 uppercase mb-2">Güncel Durum</span>
                  <p id="res-weeks-text" class="text-xl font-bold text-gray-800 m-0"></p>
                </div>
                <div class="p-6 rounded-2xl bg-white shadow-sm border border-gray-50">
                  <span class="block text-[10px] font-black text-gray-400 uppercase mb-2">Kalan Süre</span>
                  <p id="res-countdown" class="text-xl font-bold text-gray-800 m-0"></p>
                </div>
              </div>
            </div>

            <div class="mt-12 flex items-center justify-between text-[11px] font-bold text-gray-400">
              <p>Loki Medical System © 2026</p>
              <button id="reset-calc" class="text-primary hover:underline cursor-pointer">Yenile &larr;</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .calculator-section {
    background-image: 
      radial-gradient(circle at 0% 0%, rgba(var(--color-primary-rgb), 0.02) 0%, transparent 50%),
      radial-gradient(circle at 100% 100%, rgba(var(--color-secondary-rgb), 0.02) 0%, transparent 50%);
  }

  .text-gradient {
    background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--secondary)));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(0.5);
    cursor: pointer;
    transform: scale(1.5);
  }

  #result-panel {
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%239C92AC' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2v-4h4v-2h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2v-4h4v-2H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  @keyframes sparkle {
    0% { opacity: 0; transform: scale(0); }
    50% { opacity: 1; transform: scale(1.2); }
    100% { opacity: 0; transform: scale(1.5); }
  }
</style>

<script>
  function setupPregnancyCalculator() {
    const lmpInput = document.getElementById('lmp-date') as HTMLInputElement;
    const calculateBtn = document.getElementById('calculate-btn');
    const resetBtn = document.getElementById('reset-calc');
    
    // States
    const placeholder = document.getElementById('placeholder-state');
    const resultState = document.getElementById('result-state');
    
    // Displays
    const displayEdd = document.getElementById('res-edd');
    const displayWeeksLabel = document.getElementById('res-weeks-label');
    const progressBar = document.getElementById('res-progress-bar') as HTMLElement;
    const trimesterTag = document.getElementById('res-trimester-tag')?.firstElementChild as HTMLElement;
    const weeksText = document.getElementById('res-weeks-text');
    const countdownText = document.getElementById('res-countdown');

    if (!calculateBtn || !lmpInput) return;

    function reset() {
       if (placeholder && resultState) {
          resultState.classList.add('opacity-0', '-translate-y-4');
          setTimeout(() => {
            resultState.classList.add('hidden');
            placeholder.classList.remove('hidden');
            setTimeout(() => placeholder.classList.remove('opacity-0', 'translate-y-4'), 50);
          }, 500);
       }
    }

    resetBtn?.addEventListener('click', reset);

    calculateBtn.addEventListener('click', () => {
      const lmpValue = lmpInput.value;
      if (!lmpValue) {
        lmpInput.classList.add('border-primary/50', 'ring-8', 'ring-primary/5');
        setTimeout(() => lmpInput.classList.remove('border-primary/50', 'ring-8', 'ring-primary/5'), 1000);
        return;
      }

      const lmpDate = new Date(lmpValue);
      const today = new Date();
      
      // EDD calculation (280 days)
      const eddDate = new Date(lmpDate.getTime() + 280 * 24 * 60 * 60 * 1000);
      
      // Progress calculation
      const diffMs = today.getTime() - lmpDate.getTime();
      const diffDays = Math.floor(diffMs / (24 * 60 * 60 * 1000));
      const weeks = Math.floor(diffDays / 7);
      const days = diffDays % 7;
      const progressPercent = Math.min(Math.max((diffDays / 280) * 100, 0), 100);

      // Trimester
      let trimester = "1. Trimester (İlk 3 Ay)";
      if (weeks >= 14 && weeks < 28) trimester = "2. Trimester (İkinci 3 Ay)";
      if (weeks >= 28) trimester = "3. Trimester (Son 3 Ay)";

      // Countdown
      const remainingMs = eddDate.getTime() - today.getTime();
      const remainingDaysTotal = Math.max(Math.ceil(remainingMs / (24 * 60 * 60 * 1000)), 0);

      // Rendering
      if (placeholder && resultState && displayEdd && weeksText && countdownText && progressBar) {
        placeholder.classList.add('opacity-0', 'translate-y-4');
        setTimeout(() => {
          placeholder.classList.add('hidden');
          resultState.classList.remove('hidden');
          setTimeout(() => {
            resultState.classList.remove('opacity-0', '-translate-y-4');
            progressBar.style.width = `${progressPercent}%`;
          }, 50);

          displayEdd.innerText = eddDate.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
          if(displayWeeksLabel) displayWeeksLabel.innerText = `${weeks} Hafta`;
          weeksText.innerText = `${weeks} Hafta ${days} Gün`;
          countdownText.innerText = `${remainingDaysTotal} Gün`;
          if(trimesterTag) trimesterTag.innerText = trimester;
        }, 300);
      }
    });
  }

  document.addEventListener('astro:page-load', setupPregnancyCalculator);
  setupPregnancyCalculator();
</script>
