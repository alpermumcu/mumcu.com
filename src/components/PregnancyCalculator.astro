---
---

<section class="calculator-section py-20 px-4 relative overflow-hidden" id="hesaplayici">
  {/* Background glow effects */}
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-secondary/5 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-gray-900 mb-4">
        Tahmini Doğum Tarihi Hesaplayıcı
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto italic">
        "Bebeğinizle tanışacağınız o mucizevi günü yaklaşık olarak öğrenmek için son adet tarihinizi girmeniz yeterli."
      </p>
    </div>

    <div class="calculator-card glass-panel rounded-3xl p-8 md:p-12 shadow-2xl relative z-10 border border-white/50 bg-white/40 backdrop-blur-xl transition-all duration-500 hover:shadow-primary/10">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        {/* Input Area */}
        <div class="input-area">
          <label for="lmp-date" class="block text-sm font-semibold text-gray-700 mb-2 uppercase tracking-wider">
            Son Adet Tarihiniz (SAT)
          </label>
          <div class="relative group">
            <input 
              type="date" 
              id="lmp-date" 
              class="w-full h-16 px-6 rounded-2xl border-2 border-gray-100 bg-white/80 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-lg font-medium text-gray-800 placeholder-transparent group-hover:border-primary/30"
            />
          </div>
          <button 
            id="calculate-btn"
            class="mt-8 w-full h-16 bg-primary text-white font-bold rounded-2xl shadow-lg shadow-primary/30 hover:shadow-primary/40 hover:-translate-y-1 active:translate-y-0 transition-all duration-300 flex items-center justify-center gap-3 group"
          >
            <span>Öğrenmek İstiyorum</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
              <path d="M5 12h14m-7-7 7 7-7 7"/>
            </svg>
          </button>
        </div>

        {/* Info/Result Area */}
        <div id="result-display" class="result-area relative min-h-[220px] flex flex-col justify-center items-center text-center p-6 rounded-2xl bg-gradient-to-br from-primary/5 to-secondary/5 border border-primary/10 overflow-hidden">
          <div id="placeholder-info" class="transition-all duration-500">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 21a9 9 0 0 0 0-18 9 9 0 0 0 0 18z"/><path d="M12 8v4m0 4h.01"/>
              </svg>
            </div>
            <p class="text-gray-500 leading-relaxed font-medium">
              Naegele yöntemi ile Tahmini Doğum Tarihi (TDT) hesaplamak için lütfen tarihi girin.
            </p>
          </div>

          <div id="real-results" class="hidden opacity-0 transition-all duration-500 scale-95 translate-y-4 w-full">
            <h3 class="text-primary font-bold text-lg mb-2 uppercase tracking-widest">Tahmini Doğum Tarihiniz</h3>
            <p id="edd-date" class="text-4xl md:text-5xl font-display font-black text-gray-900 mb-6 drop-shadow-sm"></p>
            
            <div class="gestational-status py-3 px-6 bg-white/60 rounded-xl inline-flex items-center gap-3 border border-white shadow-sm">
              <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
              <p id="gestational-info" class="text-gray-700 font-bold m-0"></p>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="mt-8 text-center text-sm text-gray-400 italic">
      * Bu hesaplama bilgilendirme amaçlıdır. Bebeğinizin gelişimi ve kesin randevularınız için hekiminize başvurunuz.
    </div>
  </div>
</section>

<style>
  .calculator-card {
    background-image: 
      radial-gradient(circle at top right, rgba(var(--color-primary-rgb), 0.03) 0%, transparent 40%),
      radial-gradient(circle at bottom left, rgba(var(--color-secondary-rgb), 0.03) 0%, transparent 40%);
  }

  input[type="date"]::-webkit-calendar-picker-indicator {
    background-color: rgba(var(--color-primary-rgb), 0.1);
    padding: 8px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
  }

  input[type="date"]::-webkit-calendar-picker-indicator:hover {
    background-color: rgba(var(--color-primary-rgb), 0.2);
  }

  .glass-panel {
    border: 1px solid rgba(255, 255, 255, 0.4);
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-5px); }
    100% { transform: translateY(0px); }
  }

  #real-results:not(.hidden) {
    animation: slideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(20px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
</style>

<script>
  function setupCalculator() {
    const lmpInput = document.getElementById('lmp-date') as HTMLInputElement;
    const calculateBtn = document.getElementById('calculate-btn');
    const placeholderInfo = document.getElementById('placeholder-info');
    const realResults = document.getElementById('real-results');
    const eddDisplay = document.getElementById('edd-date');
    const gestationalDisplay = document.getElementById('gestational-info');

    if (!calculateBtn || !lmpInput) return;

    calculateBtn.addEventListener('click', () => {
      const lmpValue = lmpInput.value;
      if (!lmpValue) {
        lmpInput.focus();
        lmpInput.classList.add('ring-red-100', 'border-red-300');
        setTimeout(() => lmpInput.classList.remove('ring-red-100', 'border-red-300'), 2000);
        return;
      }

      const lmpDate = new Date(lmpValue);
      const today = new Date();

      // Calculation: Naegele's Rule (LMP + 280 days / 9 months 7 days)
      const eddDate = new Date(lmpDate.getTime());
      eddDate.setDate(eddDate.getDate() + 280);

      // Gestational age in weeks
      const diffTime = Math.abs(today.getTime() - lmpDate.getTime());
      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
      const weeks = Math.floor(diffDays / 7);
      const remainingDays = diffDays % 7;

      // Formatting
      const options: Intl.DateTimeFormatOptions = { day: 'numeric', month: 'long', year: 'numeric' };
      const eddStr = eddDate.toLocaleDateString('tr-TR', options);

      // Display results
      if (placeholderInfo && realResults && eddDisplay && gestationalDisplay) {
        placeholderInfo.classList.add('opacity-0', 'absolute', 'scale-90');
        setTimeout(() => placeholderInfo.classList.add('hidden'), 500);
        
        realResults.classList.remove('hidden');
        setTimeout(() => {
          realResults.classList.remove('opacity-0', 'translate-y-4', 'scale-95');
        }, 50);

        eddDisplay.innerText = eddStr;
        gestationalDisplay.innerText = `${weeks} hafta ${remainingDays > 0 ? remainingDays + ' günlük' : ''} hamilesiniz.`;
      }
    });
  }

  // Initialize
  document.addEventListener('astro:page-load', setupCalculator);
  setupCalculator();
</script>
