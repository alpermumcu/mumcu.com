<div id="reading-progress" class="reading-progress-container">
  <div id="progress-bar" class="progress-bar"></div>
</div>

<style>
  .reading-progress-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: transparent;
    z-index: 3000;
    pointer-events: none;
  }

  .progress-bar {
    height: 100%;
    width: 0%;
    background: var(--accent-gradient);
    box-shadow: 0 0 10px hsl(var(--accent) / 0.5);
    transition: width 0.1s ease-out;
    border-radius: 0 2px 2px 0;
  }
</style>

<script>
  const progressBar = document.getElementById('progress-bar');
  const container = document.getElementById('reading-progress');
  let ticking = false;

  const updateProgress = () => {
    const totalHeight = document.documentElement.scrollHeight - window.innerHeight;
    const scrollPosition = window.scrollY;
    const progress = (scrollPosition / totalHeight) * 100;
    
    if (progressBar) {
      progressBar.style.width = `${progress}%`;
    }
    ticking = false;
  };

  const onScroll = () => {
    if (!ticking) {
      window.requestAnimationFrame(updateProgress);
      ticking = true;
    }
  };

  // Only show progress on certain pages or when page is long
  window.addEventListener('scroll', onScroll, { passive: true });
  updateProgress();
</script>
