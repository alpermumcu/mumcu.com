<div id="reading-progress" class="reading-progress-container">
  <div id="progress-bar" class="progress-bar"></div>
</div>

<style>
  .reading-progress-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: transparent;
    z-index: 3000;
    pointer-events: none;
  }

  .progress-bar {
    height: 100%;
    width: 0%;
    background: var(--accent-gradient);
    box-shadow: 0 0 10px hsl(var(--accent) / 0.5);
    transition: width 0.1s ease-out;
    border-radius: 0 2px 2px 0;
  }
</style>

<script>
  const progressBar = document.getElementById('progress-bar');
  let ticking = false;
  let totalHeight = 0;

  const calculateHeight = () => {
    totalHeight = document.documentElement.scrollHeight - window.innerHeight;
  };

  const updateProgress = () => {
    // totalHeight recalculated outside of scroll loop for performance
    const scrollPosition = window.scrollY;
    const progress = totalHeight > 0 ? (scrollPosition / totalHeight) * 100 : 0;
    
    if (progressBar) {
      progressBar.style.width = `${Math.min(100, Math.max(0, progress))}%`;
    }
    ticking = false;
  };

  const onScroll = () => {
    if (!ticking) {
      window.requestAnimationFrame(updateProgress);
      ticking = true;
    }
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', () => {
    calculateHeight();
    updateProgress();
  }, { passive: true });

  // Initial calculation on load
  calculateHeight();
  updateProgress();
</script>
