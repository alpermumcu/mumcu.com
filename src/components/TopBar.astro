<div class="top-bar">
	<div class="top-bar-container">
		<div class="contact-info">
			<a href="tel:02122191202"><span>📞</span> 0212 219 12 02</a>
			<a href="mailto:randevu@mumcu.com"><span>✉️</span> randevu@mumcu.com</a>
		</div>
		<div class="social-icons">
			<a href="https://www.facebook.com/pg/mumcucom/about/" target="_blank" rel="noopener" aria-label="Facebook">FB</a>
			<a href="https://www.instagram.com/dr.alpermumcu/?hl=tr" target="_blank" rel="noopener" aria-label="Instagram">IG</a>
			<a href="https://tr.linkedin.com/in/alpermumcu" target="_blank" rel="noopener" aria-label="LinkedIn">LI</a>
			<a href="/online-randevu" class="btn-randevu">Randevu Defteri</a>
		</div>
	</div>
</div>

<style>
	.top-bar {
		background: hsl(var(--bg-main));
		border-bottom: 1px solid var(--glass-border);
		font-size: 0.85rem;
		padding: 0.6rem 1rem;
		color: hsl(var(--text-muted));
		font-weight: 500;
	}
	.top-bar-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.contact-info {
		display: flex;
		gap: 2rem;
	}
	.contact-info a {
		color: hsl(var(--text-muted));
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		transition: color 0.2s;
	}
	.contact-info a:hover {
		color: hsl(var(--accent));
	}
	.social-icons {
		display: flex;
		gap: 1.5rem;
		align-items: center;
	}
	.social-icons a {
		color: hsl(var(--text-muted));
		text-decoration: none;
		transition: color 0.2s;
	}
	.social-icons a:hover {
		color: hsl(var(--accent));
	}
	.btn-randevu {
		background: var(--accent-gradient);
		color: white !important;
		padding: 0.45rem 1.25rem;
		border-radius: 99px;
		font-weight: 700;
		box-shadow: 0 4px 12px hsl(var(--accent) / 0.2);
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.btn-randevu:hover {
		transform: translateY(-1px);
		box-shadow: 0 6px 15px hsl(var(--accent) / 0.3);
	}

	@media (max-width: 768px) {
		.contact-info {
			display: none;
		}
	}
</style>
