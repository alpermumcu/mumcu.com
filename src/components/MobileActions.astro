---
import { Icon } from 'astro-icon/components';
---
<div class="mobile-actions">
  <div class="actions-container">
    <a href="tel:05333246898" class="action-item">
      <Icon name="mdi:phone" class="icon" />
      <span class="label">Hemen Ara</span>
    </a>
    <div class="divider"></div>
    <a href="https://wa.me/905333246898" class="action-item whatsapp" target="_blank" rel="noopener">
      <Icon name="fa6-brands:whatsapp" class="icon" />
      <span class="label">WhatsApp</span>
    </a>
    <div class="divider"></div>
    <a href="/online-randevu" class="action-item primary">
      <Icon name="mdi:calendar-check" class="icon" />
      <span class="label">Randevu</span>
    </a>
  </div>
</div>

<style>
  .mobile-actions {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-top: 1px solid var(--glass-border);
    z-index: 2000;
    box-shadow: 0 -5px 20px rgba(0, 0, 0, 0.05);
    display: none;
    padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom));
  }

  .actions-container {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    justify-content: space-around;
    align-items: center;
    gap: 0.5rem;
  }

  .action-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-decoration: none;
    color: hsl(var(--text-main));
    font-size: 0.75rem;
    font-weight: 700;
    transition: all 0.2s;
  }

  .icon {
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .action-item.whatsapp {
    color: #25D366;
  }

  .action-item.primary {
    color: hsl(var(--accent));
  }

  .divider {
    width: 1px;
    height: 25px;
    background: var(--glass-border);
  }

  @media (max-width: 768px) {
    .mobile-actions {
      display: block;
    }
  }
</style>
