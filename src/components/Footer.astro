---
const today = new Date();
---

<footer class="footer">
	<div class="footer-container">
		<div class="footer-grid">
			<div class="footer-section">
				<h3>İletişim Bilgileri</h3>
				<p class="address">Lotus Nişantaşı, Halaskargazi Cd. No:38-66<br/>Kat: 5 Daire: 93, 34371 Şişli/İstanbul</p>
				<p class="phone"><strong>Tel:</strong> <a href="tel:02122191202">0(212) 219 12 02</a></p>
				<p class="phone"><strong>Gsm:</strong> <a href="tel:+16139097068">+1 613 909 70 68</a></p>
				<p class="email"><strong>E-posta:</strong> <a href="mailto:randevu@mumcu.com">randevu@mumcu.com</a></p>
			</div>
			
			<div class="footer-section">
				<h3>Çalışma Saatleri</h3>
				<ul class="hours">
					<li><span>Pazartesi – Cuma:</span> <span>10:00 – 18:30</span></li>
					<li><span>Cumartesi:</span> <span>10:00 – 14:00</span></li>
					<li><span>Pazar / Resmi Tatiller:</span> <span>Kapalı</span></li>
				</ul>
			</div>
			
			<div class="footer-section">
				<h3>Hızlı Bağlantılar</h3>
				<div class="footer-links">
					<a href="/dr-alper-mumcu">Dr. Alper Mumcu</a>
					<a href="/online-randevu">Online Randevu</a>
					<a href="/kvkk">KVKK Onam Formu</a>
					<a href="/blog">Sağlık Kütüphanesi</a>
				</div>
			</div>
		</div>
		
		<div class="footer-bottom">
			<p>&copy; {today.getFullYear()} Dr. Alper Mumcu. Tüm hakları saklıdır. <br/><small>Bu sitedeki bilgiler tıbbi danışmanlık yerine geçmez.</small></p>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: white;
		border-top: 1px solid var(--glass-border);
		padding: 6rem 1rem 3rem;
		margin-top: auto;
		color: hsl(var(--text-muted));
	}
	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 4rem;
		margin-bottom: 4rem;
	}
	h3 {
		color: hsl(var(--text-main));
		font-size: 1.25rem;
		margin-bottom: 2rem;
		font-weight: 800;
		font-family: 'Outfit', sans-serif;
	}
	p {
		margin-bottom: 0.75rem;
		font-size: 1rem;
		line-height: 1.7;
	}
	.address {
		margin-bottom: 1.5rem;
	}
	.phone, .email {
		margin-bottom: 0.5rem;
	}
	.phone a, .email a {
		color: hsl(var(--text-main));
		text-decoration: none;
		transition: color 0.2s;
	}
	.phone a:hover, .email a:hover {
		color: hsl(var(--accent));
	}
	.hours {
		list-style: none;
		padding: 0;
	}
	.hours li {
		display: flex;
		justify-content: space-between;
		margin-bottom: 0.75rem;
		font-size: 0.95rem;
		border-bottom: 1px dashed var(--glass-border);
		padding-bottom: 0.75rem;
	}
	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.footer-links a {
		color: hsl(var(--text-muted));
		text-decoration: none;
		transition: all 0.2s;
		font-weight: 500;
	}
	.footer-links a:hover {
		color: hsl(var(--accent));
		padding-left: 5px;
	}
	.footer-bottom {
		border-top: 1px solid var(--glass-border);
		padding-top: 3rem;
		text-align: center;
		font-size: 0.9rem;
	}
	small {
		opacity: 0.6;
		display: block;
		margin-top: 0.5rem;
	}
</style>
