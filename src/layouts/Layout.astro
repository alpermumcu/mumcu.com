---
import TopBar from '../components/TopBar.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import WhatsApp from '../components/WhatsApp.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import MobileActions from '../components/MobileActions.astro';
import ReadingProgress from '../components/ReadingProgress.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Alper Mumcu'nun kişisel web sitesi" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <TopBar />
    <Navigation />
    <main class="page-content">
      <slot />
    </main>
    <Footer />
    <WhatsApp />
    <ScrollToTop />
    <MobileActions />
    <ReadingProgress />
  </body>
</html>

<style is:global>
  :root {
    --bg-main: 210 40% 98%;
    --bg-card: 0 0% 100%;
    --accent: 221 83% 53%;
    --accent-light: 221 83% 85%;
    --accent-gradient: linear-gradient(
      135deg,
      hsl(var(--accent)),
      hsl(217 91% 60%)
    );
    --text-main: 222 47% 11%;
    --text-muted: 215 16% 47%;
    --glass: rgba(255, 255, 255, 0.82);
    --glass-border: rgba(0, 0, 0, 0.08);
    --shadow-sm: 0 4px 6px -1px rgb(0 0 0 / 0.05);
    --shadow-md: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    --whatsapp: 142 69% 49%;
  }
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html {
    font-family: 'Inter', system-ui, sans-serif;
    background: hsl(var(--bg-main));
    color: hsl(var(--text-main));
    scroll-behavior: smooth;
  }
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }
  h1, h2, h3, h4, .font-outfit {
    font-family: 'Outfit', sans-serif;
  }
  .page-content {
    flex: 1;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .glass {
    background: var(--glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
  }
  .text-gradient {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  section {
    padding: 5rem 0;
  }
  @media (max-width: 768px) {
    section {
      padding: 3rem 0;
    }
  }
</style>
